# Copy to .env.local for local dev.

# Postgres — Railway injects this as ${{Postgres.DATABASE_URL}} in production.
DATABASE_URL="postgres://postgres:postgres@localhost:5432/pmc_web"

# PMC backend API (the FastAPI we built in pmc.serve.api).
# In production, point at your deployed orchestrator.
PMC_API_URL="http://localhost:8000"

# Resend for magic-link emails.
RESEND_API_KEY=""
EMAIL_FROM="hello@thepersonalmodelcompany.com"

# Auth — secret for signing session cookies. Generate with: openssl rand -hex 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Optional: explicit base URL for absolute redirects in emails / cookies.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
