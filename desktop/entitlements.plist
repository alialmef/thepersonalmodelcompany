<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for hardened runtime + JIT in the system webview (WebKit JITs JS) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Required for dyld to load the Tauri runtime libraries -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- AppleScript bridge (read Notes/Mail via Apple Events) — only fires if user grants -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!-- File access — user-selected only (Apple Mail .mbox, document uploads). No broad disk read. -->
    <key>com.apple.security.files.user-selected.read-only</key>
    <true/>
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
</dict>
</plist>
